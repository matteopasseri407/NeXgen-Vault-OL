# Secrets for the self-hosted stack. Copy to .env and fill in.
# Never commit the real .env file.

# Firecrawl (optional, for LLM-powered extract endpoints)
OPENAI_API_KEY=

# n8n MCP server token (enable in n8n Settings → MCP Server, then set here
# and on the workstation env so agents can connect). n8n/docker-compose.yml
# now actually passes this to the container -- it used to be commented out
# there, so filling this in used to have no effect (fixed 2026-07-12).
N8N_MCP_TOKEN=

# Vault MCP token (if you deploy the vault-library MCP container — optional)
VAULT_LIBRARY_TOKEN=

# n8n encryption key — n8n uses this to encrypt every credential it stores
# (API keys, OAuth tokens, webhook secrets, everything in its credentials
# store). Leave this BLANK: bootstrap-vps.sh auto-generates one with
# `openssl rand -hex 32` on first run and writes it into your local .env
# (git-ignored, chmod 600) — it never overwrites a key that's already
# there. Never invent or type a value here yourself. If this is left unset
# AND bootstrap-vps.sh is skipped, n8n falls back to auto-generating its
# own key INSIDE the n8n-data volume — which then ends up in plaintext
# inside every backup tarball made by backup-restore.sh.
N8N_ENCRYPTION_KEY=

# Vault OCR API bearer token (optional). Leave empty to keep the OCR API's
# historical no-auth behavior for local/tunnel-only use (it logs a WARN once
# instead of blocking). To require it: generate one value and set it here --
# both the API (ocr/api/app.py) and its MCP client (ocr/mcp/vault_ocr_mcp.py)
# read this same VAULT_OCR_TOKEN, so one value covers both sides.
#   openssl rand -hex 32
VAULT_OCR_TOKEN=

# Firecrawl Redis password (finding C). Leave empty and run bootstrap-vps.sh:
# it auto-generates this on first run (openssl rand -hex 32) if unset, so you
# never have to invent or remember it by hand. Only set it yourself if you
# need a specific value (e.g. restoring a value used elsewhere).
FIRECRAWL_REDIS_PASSWORD=

# Timezone for n8n schedules
TZ=UTC

# --- Image pins (optional) ---
# Every service already has a pinned, non-"latest" default baked into its
# docker-compose.yml. Set one of these only to override that default, e.g.
# for a rollback (see backup-restore.sh rollback) — you do not need to fill
# these in for a normal deploy. Uncomment and edit to override:
# N8N_IMAGE=n8nio/n8n:2.29.10
# OCR_IMAGE=vault-ocr-api:1.0.0
# FIRECRAWL_IMAGE=ghcr.io/mendableai/firecrawl:2.11.0
# FIRECRAWL_REDIS_IMAGE=redis:8.2.7-alpine
# FIRECRAWL_PLAYWRIGHT_IMAGE=ghcr.io/mendableai/firecrawl-playwright-service:2.11.0
