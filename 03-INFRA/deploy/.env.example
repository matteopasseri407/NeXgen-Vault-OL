# Secrets for the self-hosted stack. Copy to .env and fill in.
# Never commit the real .env file.

# Firecrawl (optional, for LLM-powered extract endpoints)
OPENAI_API_KEY=

# Firecrawl deep Web search (optional for scrape-only installs, required for
# the full Cloud-Server search lane). Create a Brave Search API key, paste it
# here, then set the Brave dashboard usage limit to "Free credits only".
# bootstrap-vps.sh detects a non-empty value and enables the pinned SearXNG
# overlay automatically. The key is rendered into SearXNG at container start
# and is never committed or passed on a command line.
BRAVE_SEARCH_API_KEY=

# Private SearXNG session secret. Leave blank: bootstrap-vps.sh generates it
# on first use when BRAVE_SEARCH_API_KEY is configured.
FIRECRAWL_SEARXNG_SECRET=

# n8n MCP server token (enable in n8n Settings → MCP Server, then set here
# and on the workstation env so agents can connect). n8n/docker-compose.yml
# now actually passes this to the container -- it used to be commented out
# there, so filling this in used to have no effect (fixed 2026-07-12).
N8N_MCP_TOKEN=

# Vault MCP bearer token — auth for the vault-mcp container (vault-mcp/
# docker-compose.yml) AND the workstation CLIs (manifest.yaml reads the same
# variable name), so one value covers both sides like VAULT_OCR_TOKEN.
# Leave BLANK: bootstrap-vps.sh auto-generates it on first run (openssl
# rand -hex 32) and never overwrites an existing value. Unlike the OCR
# token this one is NOT optional — the vault-mcp instance has write tools
# enabled and refuses to start without auth.
VAULT_LIBRARY_TOKEN=

# n8n encryption key — n8n uses this to encrypt every credential it stores
# (API keys, OAuth tokens, webhook secrets, everything in its credentials
# store). Leave this BLANK: bootstrap-vps.sh auto-generates one with
# `openssl rand -hex 32` on first run and writes it into your local .env
# (git-ignored, chmod 600) — it never overwrites a key that's already
# there. Never invent or type a value here yourself. If this is left unset
# AND bootstrap-vps.sh is skipped, n8n falls back to auto-generating its
# own key INSIDE the n8n-data volume — which then ends up in plaintext
# inside every backup tarball made by backup-restore.sh.
N8N_ENCRYPTION_KEY=

# Vault OCR API bearer token (optional). Leave empty to keep the OCR API's
# historical no-auth behavior for local/tunnel-only use (it logs a WARN once
# instead of blocking). To require it: generate one value and set it here --
# both the API (ocr/api/app.py) and its MCP client (ocr/mcp/vault_ocr_mcp.py)
# read this same VAULT_OCR_TOKEN, so one value covers both sides.
#   openssl rand -hex 32
VAULT_OCR_TOKEN=

# Firecrawl Redis password (finding C). Leave empty and run bootstrap-vps.sh:
# it auto-generates this on first run (openssl rand -hex 32) if unset, so you
# never have to invent or remember it by hand. Only set it yourself if you
# need a specific value (e.g. restoring a value used elsewhere).
FIRECRAWL_REDIS_PASSWORD=

# Firecrawl NUQ Postgres password (2.11 architecture). Same rule as the
# Redis password above: leave empty, bootstrap-vps.sh auto-generates it.
# NOTE: the value is baked into the Postgres data volume on first boot —
# if you restore a firecrawl-nuq-data backup, restore the matching value.
FIRECRAWL_POSTGRES_PASSWORD=

# Timezone for n8n schedules
TZ=UTC

# --- vault-mcp (optional overrides) ---
# VAULT_MCP_UID / VAULT_MCP_GID are pinned automatically by bootstrap-vps.sh
# (the deploy user's uid/gid, so Git sees one owner on the mounted repo) —
# don't fill them by hand. Paths only need overriding if the defaults from
# vault-mcp/provision-vault-repo.sh don't suit the host:
# VAULT_WORKTREE_DIR=/opt/knowledge-vault
# VAULT_BARE_DIR=/opt/knowledge-vault.git

# --- Image pins (optional) ---
# Every service already has a pinned, non-"latest" default baked into its
# docker-compose.yml. Set one of these only to override that default, e.g.
# for a rollback (see backup-restore.sh rollback) — you do not need to fill
# these in for a normal deploy. Uncomment and edit to override:
# N8N_IMAGE=n8nio/n8n:2.29.10
# OCR_IMAGE=vault-ocr-api:1.0.0
# VAULT_MCP_IMAGE=vault-mcp:0.1.0
# FIRECRAWL_IMAGE=ghcr.io/firecrawl/firecrawl:2.11.99
# FIRECRAWL_REDIS_IMAGE=redis:8.2.7-alpine
# FIRECRAWL_RABBITMQ_IMAGE=rabbitmq:3.13.7-management
# FIRECRAWL_SEARXNG_IMAGE=docker.io/searxng/searxng@sha256:...
# nuq-postgres and playwright-service publish only `latest` on ghcr, so the
# compose pins them by sha256 DIGEST (see firecrawl/docker-compose.yml header
# for how to resolve a newer one):
# FIRECRAWL_NUQ_POSTGRES_IMAGE=ghcr.io/firecrawl/nuq-postgres@sha256:...
# FIRECRAWL_PLAYWRIGHT_IMAGE=ghcr.io/firecrawl/playwright-service@sha256:...
# ghcr.io/mendableai/* (the old registry) no longer resolves -- see the
# VERIFIED 2026-07-12 note in firecrawl/docker-compose.yml.
