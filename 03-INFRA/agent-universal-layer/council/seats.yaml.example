# Template del piano dati utente per il Consiglio delle AI.
#
# Il motore pubblico non prescrive QUALI modelli usare: la scelta dipende
# dagli abbonamenti che hai, da cosa esce ogni mese come frontier, dal
# budget. Questo file è solo lo schema + i criteri generali; le scelte vere
# vivono nel tuo piano dati (fuori dal motore, mai committato qui), di
# default in:
#   $AGENT_VAULT_DATA/03-INFRA/agent-universal-layer/council/seats.yaml
# (AGENT_VAULT_DATA non impostata => $KNOWLEDGE_VAULT_PATH => ~/KnowledgeVault,
# stesso pattern di AGENT_ENGINE_ROOT/AGENT_VAULT_DATA usato da agent_sync.py).
#
# Senza un seats.yaml valido in quel percorso, `council` si ferma e spiega
# cosa manca: l'espansione è disattivata di default, zero dipendenze forzate.
#
# Criteri generali per scegliere i seat (non i modelli specifici):
#   - usa CLI già pagate ad abbonamento flat che hai comunque, mai una nuova
#     API a consumo aperta solo per questo;
#   - il vendor di un seat consultato deve essere diverso dal vendor che ha
#     prodotto il materiale in esame (niente auto-review dello stesso vendor);
#   - preferisci seat con garanzia zero-retention per materiale reale;
#     seat senza quella garanzia (es. tier gratuiti che riusano i dati per
#     training) vanno bene solo per test tecnici con contenuto non sensibile;
#   - verifica la policy dati del canale con una fonte primaria (pagina
#     privacy/ToS del provider), non fidarti di riassunti di terzi.
#
# Schema di ogni seat:
#   <nome-seat>:
#     vendor: <vendor del modello, es. openai/anthropic/deepseek/zhipu/...>
#     cli: <CLI locale che lo invoca in headless, es. opencode/agy/codex>
#     model: <identificatore modello nel formato atteso dalla CLI>
#     quota_pool: <pool reale condiviso, es. opencode-go>  # opzionale ma consigliato
#     timeout_seconds: 300  # opzionale, default conservativo: 300 secondi
#     zero_retention: true|false   # garanzia contrattuale di non-training,
#                                  # da verificare con fonte primaria
#
# Schema sequence per il mode `relay`:
# - i ruoli NON vivono dentro i seat;
# - la sequence dichiara ruolo -> seat primario e fallback ammessi;
# - i fallback validi per un ruolo sono SOLO quelli dichiarati qui.
#
# Puoi anche passare una sequence inline:
#   council relay "brief" --sequence architect=seat-a|seat-b,builder=seat-c,reviewer=seat-d
# oppure definire sequence nominate:
#
# sequences:
#   default:
#     - role: architect
#       seats: [seat-a, seat-b]  # seat-b e' fallback esplicito, non improvvisato
#     - role: builder
#       seat: seat-c
#     - role: reviewer
#       seat: seat-d

# Campo root obbligatorio, aggiornalo solo con una migrazione documentata.
schema_version: 1

seats:
  esempio-seat:
    vendor: nome-vendor
    cli: nome-cli
    model: provider/nome-modello
    quota_pool: nome-cli-provider
    zero_retention: false
