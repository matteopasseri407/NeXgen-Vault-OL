# ============================================================================
# SKILLS MANIFEST (example)  ·  agent-universal-layer — single source of truth
# ----------------------------------------------------------------------------
# Copy this file to `skills.manifest.yaml` in the same folder, then edit it to
# declare every "chosen" skill ONCE. `skills-sync.py` materializes each entry
# into the non-discovered library `~/.agents/skill-library/` and builds only the
# runtime views you deliberately ask for. You choose here; the rest is synced.
#
#   Linux/macOS: cp skills.manifest.yaml.example skills.manifest.yaml
#   Windows:     Copy-Item skills.manifest.yaml.example skills.manifest.yaml
#
# Workflow ("choose a skill once -> it's everywhere"):
#   1. add an entry under `skills:` below
#   2. git commit + push (so every machine sees it)
#   3. on each machine: git pull && python3 03-INFRA/scripts/skills-sync.py --apply
#      (Windows: py -3 03-INFRA/scripts/skills-sync.py --apply; or let
#       `agent-sync guard` run it for you)
#
# RULES (these mirror the MCP manifest, mcp/manifest.yaml):
#   origin: vault   -> vendored inside this repo at
#                      03-INFRA/agent-universal-layer/skills/<name>/ ; git
#                      carries it to every machine. Use for skills you own/edit.
#   origin: github  -> third-party, NOT vendored: inventoried here only. Every
#                      entry needs the FULL commit SHA, so the exact bytes always
#                      reinstall from the same upstream revision (restorable).
#   targets:  the runtimes that surface the skill natively: claude and
#             antigravity get per-skill views; codex reads core skills from
#             the shared ~/.agents/skills root; opencode reads the shared
#             roots too (its target only verifies discoverability). Skills
#             kept out of every eager view are still reachable through the
#             universal `agent-skill find|show` command.
#   exposure: manual (default — invisible to eager runtimes, loaded lazily) or
#             core (the single exception, visible under ~/.agents/skills).
#
# ADDITIVE by design: unregistered legacy skills are never deleted.
# `skills-sync.py --apply --migrate-legacy` quarantines them locally, out of the
# discovery roots, until you promote or discard them.
# Per-owner / team skills (only sync on their owner's machine): see docs/team.md.
# ============================================================================

skills:

  # --- starter command skills (shipped with the engine) ----------------------
  # A cross-CLI "command" is just a skill exposed everywhere. The recipe:
  #   exposure: core          -> lands in ~/.agents/skills, which Codex
  #                              ("$name" mention) and OpenCode ("/name")
  #                              read natively.
  #   targets: [claude]       -> native lazy view for Claude Code ("/name").
  #   targets: [antigravity]  -> native view in ~/.gemini/antigravity-cli/skills
  #                              ("/name" in the Antigravity TUI).
  #   targets: [opencode]     -> writes nothing (OpenCode reads the shared
  #                              roots); sync only verifies discoverability.
  # Keep names lowercase-hyphen (agentskills.io shape) and avoid CLI built-in
  # names: e.g. Claude Code ships a bundled /doctor that a skill named
  # "doctor" would override -- hence the vault- prefix below.
  # Write bodies argument-free ("the text after the command is the request"):
  # placeholder syntaxes like $ARGUMENTS diverge per CLI, plain instructions
  # work identically on all four.
  vault-doctor:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  vault-close:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  vault-save:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  vault-council:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  vault-groom:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  vault-update:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  vault-map:
    origin: vault
    targets: [claude, antigravity, opencode]
    exposure: core

  # --- example: a third-party skill, inventoried by pinned commit ------------
  # humanizer:
  #   origin: github
  #   repo: <owner>/<repo>
  #   commit: <full-40-character-commit-sha>   # required for origin: github
  #   targets: [claude]
  #   exposure: manual

  # --- example: your own skill, vendored in this repo under skills/<name>/ ----
  # my-custom-skill:
  #   origin: vault
  #   targets: [claude]
  #   exposure: manual
