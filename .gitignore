# Never commit secrets or local-only state.
# Ignore the folder CONTENTS (not the folder itself, so the whitelist below
# works — a trailing-slash `99-SECRETS/` would exclude the dir and kill the
# negations, leaving the scaffold untracked).
99-SECRETS/*
!99-SECRETS/.gitkeep
!99-SECRETS/README.md
!99-SECRETS/secrets-registry.md
# archive/ (the encrypted .gpg vault) stays ignored: created on first secret.
99-SECRETS/archive/

# Any local env file, anywhere in the tree (not just deploy/.env) — but
# .env.example files are meant to be committed (placeholders only, see
# SECURITY.md), so they're explicitly un-ignored.
.env
.env.*
*.env
!.env.example
!*.env.example

# Backups, logs, and sandbox residue from local runs (render.py backups,
# test sandboxes, leftover scratch dirs) — S0 anti-leak hardening, 2026-07-08
*.bak-*
*.log
*.sandbox
tmp-sandbox-*/

# n8n volume backup archives (backup-restore.sh) — as sensitive as every
# credential n8n has ever managed; chmod 600/700'd on disk, must never be
# tracked. Secrets-at-rest hardening, 2026-07-12.
03-INFRA/deploy/backups/

# Keys and credentials, wherever they land
*.key
*.pem
*.pfx
id_rsa
id_ed25519

# Session artifacts from agent CLIs, if ever run inside this repo
.claude/
.agents/

# Generated Windows runtime wrapper. It contains machine-specific absolute
# paths and belongs in per-user state, never in the public source checkout.
03-INFRA/scripts/start-agent-sync-hidden.vbs

# Python noise (scripts generate this on run)
__pycache__/
*.pyc
.pytest_cache/

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
*.lnk
*.swp
*.swo
*~
.idea/
.vscode/
